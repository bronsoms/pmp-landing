<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% if home %}
    <title>{{ home.es.meta_title }}</title>
    <meta name="description" content="{{ home.es.meta_description }}">
    {% else %}
    <title>{{ site.title }}</title>
    <meta name="description" content="{{ site.description }}">
    {% endif %}
    <link rel="alternate" hreflang="es" href="?lang=es">
    <link rel="alternate" hreflang="ca" href="?lang=ca">
    <link rel="alternate" hreflang="en" href="?lang=en">
    <link rel="alternate" hreflang="x-default" href="?lang=es">
    <script>
        (function(){
            var p = new URLSearchParams(window.location.search).get('lang');
            var l = p || localStorage.getItem('pmp-lang') || 'es';
            if (l !== 'es') document.documentElement.style.opacity = '0';
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
</head>
<body>
    {{ content | safe }}

    <script>
    {% if home %}
        const translations = {{ home.translations | dump | safe }};
    {% else %}
        const translations = {{ translations | dump | safe }};
    {% endif %}
    </script>
    <script src="{{ '/js/main.js' | url }}"></script>
    <script src="https://app.storyblok.com/f/storyblok-v2-latest.js"></script>
    <script>
        if (window.StoryblokBridge) {
            const storyblokInstance = new StoryblokBridge();
            storyblokInstance.on('input', function(event) {
                window.location.reload();
            });
            storyblokInstance.on('published', function() {
                window.location.reload();
            });
            storyblokInstance.on('change', function() {
                window.location.reload();
            });
        }
    </script>
</body>
</html>
