<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% if home %}
    <title>{{ home.es.meta_title }}</title>
    <meta name="description" content="{{ home.es.meta_description }}">
    {% else %}
    <title>{{ site.title }}</title>
    <meta name="description" content="{{ site.description }}">
    {% endif %}
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
</head>
<body>
    {{ content | safe }}

    <script src="{{ '/js/main.js' | url }}"></script>
    <script src="https://app.storyblok.com/f/storyblok-v2-latest.js"></script>
    <script>
        if (window.StoryblokBridge) {
            const storyblokInstance = new StoryblokBridge();
            storyblokInstance.on('input', function(event) {
                window.location.reload();
            });
            storyblokInstance.on('published', function() {
                window.location.reload();
            });
            storyblokInstance.on('change', function() {
                window.location.reload();
            });
        }
    </script>
</body>
</html>
