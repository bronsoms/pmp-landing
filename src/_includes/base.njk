<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grup PMP — Pioneros en Construcción Industrializada</title>
    <meta name="description" content="Grup PMP es una organización pionera en construcción industrializada con más de 25 años de experiencia. Soluciones adaptadas para particulares y profesionales.">
    <link rel="canonical" href="https://grup-pmp.com/">
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Grup PMP",
        "url": "https://grup-pmp.com",
        "logo": "https://grup-pmp.com/assets/logo-gruppmp.svg",
        "description": "Organización pionera en construcción industrializada con más de 25 años de experiencia. Sistema constructivo patentado Khanvian®.",
        "foundingDate": "1999",
        "telephone": "+34973603954",
        "email": "miproyecto@pmp-pretaporter.com",
        "address": {
            "@type": "PostalAddress",
            "addressLocality": "Lleida",
            "addressCountry": "ES"
        },
        "areaServed": ["Lleida", "Barcelona", "Girona", "Andorra", "Madrid", "Ibiza"],
        "numberOfEmployees": {
            "@type": "QuantitativeValue",
            "value": "50+"
        },
        "knowsAbout": ["Construcción industrializada", "Construcción modular", "Sistema Khanvian", "Edificación sostenible"],
        "subOrganization": [
            {
                "@type": "Organization",
                "name": "Prêt-à-porter casas",
                "url": "https://www.pretaportercasas.com",
                "description": "Proyectos personalizados de arquitectura innovadora con interiores y acabados de primera."
            },
            {
                "@type": "Organization",
                "name": "Prêt-à-porter studio",
                "description": "Estudio de interiorismo y decoración."
            },
            {
                "@type": "Organization",
                "name": "àParts",
                "description": "Alianzas y colaboraciones estratégicas con partners tecnológicos y constructivos."
            }
        ]
    }
    </script>
</head>
<body>
    {{ content | safe }}

    <script src="{{ '/js/main.js' | url }}"></script>
</body>
</html>
